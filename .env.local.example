# Web3Forms access key for the contact form.
# Get a free key at https://web3forms.com (enter your email — they mail you the key).
# Copy this file to .env.local and paste your key below.
NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# (Optional) Cloudflare Turnstile site key — spam protection for the contact form.
# Create a free widget at https://dash.cloudflare.com → Turnstile, then:
#   1. Paste the SITE key below.
#   2. Add the SECRET key in your Web3Forms dashboard so it validates the token.
# Leave blank to disable Turnstile (the form still works with the cooldown + honeypot).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
